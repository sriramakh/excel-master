# ── LLM Provider ─────────────────────────────────────────────
# Choose one: "openai" or "minimax"
LLM_PROVIDER=openai

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
MODEL=gpt-4o

# ── MiniMax (alternative provider) ───────────────────────────
# MINIMAX_API_TOKEN=your-minimax-api-token-here
# MINIMAX_MODEL=MiniMax-Text-01

# ── LLM Parameters ──────────────────────────────────────────
MAX_TOKENS=4096
TEMPERATURE=0.3
MAX_RETRIES=3

# ── Paths (optional, defaults shown) ────────────────────────
# DATA_DIR=data
# OUTPUT_DIR=output
